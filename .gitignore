# Machine-local project registry (bootstrapped from registry.example.yml by setup.sh)
registry.yml

# Machine-local system map — your real repo topology (bootstrapped from
# system-map.example.yml by setup.sh). The example is tracked; your real one isn't.
system-map.yml

# Machine-local model policy (bootstrapped from models.example.yml by setup.sh /
# configure-models.sh) and the stamped skill/agent copies generated from it
models.yml
build/

# Disposable clone cache for onboarding repo briefs (<hub>/.cache/repos/<repo>/)
.cache/

# Repo briefs describe YOUR governed repos (build commands, architecture, gotchas)
# — generated by /sdd:onboard, machine/user-local, never committed. Only the
# lifecycle README is tracked.
briefs/*.md
!briefs/README.md

.DS_Store
